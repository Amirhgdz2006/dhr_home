# Database connection URI
# Example: mongodb://localhost:27017/database_name
MONGODB_URI=Your MongoDB connection string here

# Backend server port
# Example: 1338
PORT=Port number your backend will run on

# JWT secret key (used to sign tokens)
# Example: a long random string
JWT_SECRET_CODE=Your JWT secret key here

# JWT token expiration time
# Example: 1d, 12h, 3600s
JWT_EXPIRE_TIME=Token expiration duration

# Time window for the authentication endpoint rate limit
# Unit: milliseconds (ms)
# Example: 10 minutes = 600000 ms
RATE_LIMIT_WINDOW_MS=Your time window in milliseconds

# Maximum number of allowed requests per time window
# Must be a positive integer
# Example: 3 requests per 10 minutes
RATE_LIMIT_MAX=Your maximum requests allowed in the time window

# Frontend URL (for CORS and redirects)
# Example: http://localhost:3000
FRONTEND_URL=Your frontend URL here
